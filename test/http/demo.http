# ─── clear-fraud-1 (actualFraud=true) ─────────────────────────
# Fraud; no police report and added supplements — multiple red flags.

POST {{intakeUrl}}/submitClaim
Content-Type: application/json

{
  "externalRef": "DEMO-CLEAR-FRAUD-01",
  "rawText": "It was a Sunday afternoon in late July, my wife and I were driving up to her parents' cabin on a quiet country road. I'd been keeping the speed reasonable in my Honda Sport - it's a high-end coupe, only four years old - when I lost grip on loose gravel coming out of a curve and slid into the verge. The car came to rest against a low embankment. The damage was more than I'd expected from a slow slide: front bumper cracked, hood creased, fender bent, and the body shop later found radiator and frame issues. I was alone, no other vehicles involved at that hour. We got the car towed and back home eventually. I sat on the claim through autumn and winter because the cabin trips kept us busy and I figured the insurance could wait, finally filed in January. $400 deductible.",
  "predictModels": [
    "sap-rpt-1-large",
    "gbc"
  ],
  "evaluations": [
    {
      "model": "anthropic--claude-4.6-opus",
      "inputPredictModel": "sap-rpt-1-large"
    },
    {
      "model": "gpt-oss-120b",
      "inputPredictModel": "gbc"
    }
  ],
  "actualFraud": true
}

###

# ─── clear-fraud-2 (actualFraud=true) ─────────────────────────
# Fraud; recent address change shortly before the claim.

POST {{intakeUrl}}/submitClaim
Content-Type: application/json

{
  "externalRef": "DEMO-CLEAR-FRAUD-02",
  "rawText": "It was a Monday in mid-December and I was driving back from a friend's lake house on a quiet country road when I hit a deep pothole I hadn't seen coming. My Toyota Sedan is a mid-priced car, well past seven years. Front suspension took the impact straight on, both lower control arms ended up bent, and the alloy was cracked - the body shop later flagged steering rack and frame stress on that side too, which all falls under my comprehensive cover. We'd just moved to the area a few months earlier so I didn't really know my way around yet. No other vehicles involved. The body shop has been working through more than a half-dozen supplements as they uncovered more, and the paperwork finally wrapped up in May. I have two vehicles in the household, first claim on this policy. $400 deductible.",
  "predictModels": [
    "sap-rpt-1-large",
    "gbc"
  ],
  "evaluations": [
    {
      "model": "anthropic--claude-4.6-opus",
      "inputPredictModel": "sap-rpt-1-large"
    },
    {
      "model": "gpt-oss-120b",
      "inputPredictModel": "gbc"
    }
  ],
  "actualFraud": true
}

