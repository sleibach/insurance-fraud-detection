# ─── borderline-fraud-1 (actualFraud=true) ─────────────────────────
# Fraud despite benign-looking signals (no supplements, no address change).

POST {{intakeUrl}}/submitClaim
Content-Type: application/json

{
  "externalRef": "DEMO-BORDERLINE-FRAUD-01",
  "rawText": "It was a Saturday in early July, my first summer with the Honda Sedan - a high-end model my parents had put on the policy when I got my license. I was pulling out of a parking space at a shopping centre, alone in the car, when I clipped a low bollard with the rear corner. The contact felt minor at the time, almost just a tap, but when I got out the damage was extensive: the bumper cracked, the trunk wouldn't close properly, and the rear quarter had a deep dent. My friend who was riding with me said he didn't even feel the impact. There was no one else around at that hour, no other vehicles involved. I sat on the whole thing through the rest of the summer because I was nervous about telling my parents, and only filed the claim in early September. $400 deductible.",
  "predictModels": [
    "sap-rpt-1-large",
    "gbc"
  ],
  "evaluations": [
    {
      "model": "anthropic--claude-4.6-opus",
      "inputPredictModel": "sap-rpt-1-large"
    },
    {
      "model": "gpt-oss-120b",
      "inputPredictModel": "gbc"
    }
  ],
  "actualFraud": true
}

