### Insurance Fraud Detection — Live Demo (curated Tathergang cases)
### Generated from test/fixtures/demo-cases.json (scripts/extract-demo-cases.ts).
### Each case carries a known actualFraud label so the UI shows predicted-vs-actual
### per model. Submit a few, then open the Claims tab / ./monitor.http to compare.
###
### Pipeline (default isolated tracks): predict = sap-rpt-1-large + gbc;
###   evaluate = Claude←RPT (proprietary) and gpt-oss-120b←gbc (open source).

@intakeUrl = http://localhost:4004/api/intake

# ─── clear-legit-1 (actualFraud=false) ─────────────────────────
# No fraud; police report filed, straightforward incident.

POST {{intakeUrl}}/submitClaim
Content-Type: application/json

{
  "externalRef": "DEMO-CLEAR-LEGIT-01",
  "rawText": "I had a single-vehicle accident on a Wednesday in mid-January. Coming back through the city late at night in my Honda Sport - the high-trim version - I hit ice on an off-ramp and clipped the concrete barrier. The front quarter panel, headlight, and bumper assembly all took the hit. I called the police given the location and they filed a report, even though no one else was involved. I'm in my mid-thirties, this is my first claim on this policy, and I'm covering the $400 deductible.",
  "predictModels": [
    "sap-rpt-1-large",
    "gbc"
  ],
  "evaluations": [
    {
      "model": "anthropic--claude-4.6-opus",
      "inputPredictModel": "sap-rpt-1-large"
    },
    {
      "model": "gpt-oss-120b",
      "inputPredictModel": "gbc"
    }
  ],
  "actualFraud": false
}

###

# ─── clear-legit-2 (actualFraud=false) ─────────────────────────
# No fraud; police report filed, plausible single-vehicle accident.

POST {{intakeUrl}}/submitClaim
Content-Type: application/json

{
  "externalRef": "DEMO-CLEAR-LEGIT-02",
  "rawText": "\"In late June I was driving back from a fishing trip on a country road - my Toyota Sport is a modest, well-used car, well past its prime but still reliable - when another driver came round a bend too fast and clipped my rear quarter. I lost control briefly and ended up half in the verge. We both got out, no injuries, but his car was clearly at fault and we called the police given how remote the spot was. The repair has stretched out - more parts kept getting added to the bill - and the supplements have piled up. I'm in my sixties; second claim on this policy. $400 deductible.\"",
  "predictModels": [
    "sap-rpt-1-large",
    "gbc"
  ],
  "evaluations": [
    {
      "model": "anthropic--claude-4.6-opus",
      "inputPredictModel": "sap-rpt-1-large"
    },
    {
      "model": "gpt-oss-120b",
      "inputPredictModel": "gbc"
    }
  ],
  "actualFraud": false
}

