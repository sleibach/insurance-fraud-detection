{
  "_version": "1.65.0",
  "sap.app": {
    "id": "claims",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.18.0",
      "toolsId": "157160e5-0e0b-4856-b7d2-ac1e89e5dbe9"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/ClaimService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.suite.ui.commons": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "claims.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ClaimsList",
          "target": "ClaimsList"
        },
        {
          "pattern": "Claims({key}):?query:",
          "name": "ClaimsObjectPage",
          "target": "ClaimsObjectPage"
        }
      ],
      "targets": {
        "ClaimsList": {
          "type": "Component",
          "id": "ClaimsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Claims",
              "variantManagement": "Page",
              "navigation": {
                "Claims": {
                  "detail": {
                    "route": "ClaimsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "columns": {
                    "DataField::externalRef": {
                      "width": "10rem"
                    },
                    "DataField::claimType::name": {
                      "width": "10rem"
                    },
                    "PipelineFlow": {
                      "header": "Processing",
                      "position": {
                        "anchor": "DataField::claimType::name",
                        "placement": "After"
                      },
                      "template": "claims.ext.fragment.PipelineFlowCompact",
                      "horizontalAlign": "Begin",
                      "width": "15rem"
                    },
                    "DataField::title": {
                      "width": "14rem"
                    }
                  }
                }
              },
              "initialLoad": "Enabled",
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#table"
            }
          }
        },
        "ClaimsObjectPage": {
          "type": "Component",
          "id": "ClaimsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Claims",
              "content": {
                "header": {
                  "facets": {
                    "PipelineFlow": {
                      "template": "claims.ext.fragment.PipelineFlow",
                      "position": {
                        "placement": "End"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
